[
    {
        "start": 0.0,
        "end": 3.76,
        "text": "This is a student who's nervous to present, so let's help them gain some aura."
    },
    {
        "start": 3.76,
        "end": 8.4,
        "text": "First, I want you to lift your head and look out, make eye contact with your lovely audience,"
    },
    {
        "start": 8.4,
        "end": 10.56,
        "text": "or look towards the back if you're too nervous."
    },
    {
        "start": 10.56,
        "end": 12.08,
        "text": "But what about my notes?"
    },
    {
        "start": 12.08,
        "end": 13.44,
        "text": "Bro, those aren't notes."
    },
    {
        "start": 13.44,
        "end": 14.72,
        "text": "That is a script."
    },
    {
        "start": 14.72,
        "end": 19.12,
        "text": "Swap that out for some flashcards that just hit the main points, then add the rest."
    },
    {
        "start": 19.12,
        "end": 23.28,
        "text": "Okay, um, um, you know, know what?"
    },
    {
        "start": 23.28,
        "end": 26.32,
        "text": "Replace those fellow words with pauses to sound more confident,"
    },
    {
        "start": 26.32,
        "end": 28.56,
        "text": "but you also need to look more confident."
    },
    {
        "start": 28.64,
        "end": 29.84,
        "text": "Wide in your stance."
    },
    {
        "start": 29.84,
        "end": 30.56,
        "text": "Good."
    },
    {
        "start": 30.56,
        "end": 32.0,
        "text": "Now relax your arms."
    },
    {
        "start": 32.0,
        "end": 32.72,
        "text": "Perfect."
    },
    {
        "start": 32.72,
        "end": 34.32,
        "text": "And now ease your face."
    },
    {
        "start": 34.32,
        "end": 35.44,
        "text": "Am I good to begin?"
    },
    {
        "start": 35.44,
        "end": 37.44,
        "text": "Yeah, just be sure to follow Gohar."
    }
]